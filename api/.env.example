# ============================================================
# Hoshloop SEO Engine — Environment Variables
# ============================================================

# --- Core (required) ---
ANTHROPIC_API_KEY=sk-ant-xxx          # Claude E-E-A-T + content generation
API_SECRET_KEY=your-secret-key-here   # Shared secret with engine-hoshloop frontend
PORT=8000

# --- Database (required for growth features) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Vercel Postgres: copy from your Vercel project → Storage → .env.local

# --- Phase 1: DataForSEO (strike zone keywords + backlinks) ---
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your-api-password
# Sign up at app.dataforseo.com — ~$50/mo for typical SaaS usage

# --- Phase 1: Google Search Console OAuth ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# Redirect URI to register in Google Cloud Console:
# https://engine.hoshloop.com/api/gsc/callback
GSC_REDIRECT_URI=https://web-production-424e4.up.railway.app/api/gsc/callback
FRONTEND_URL=https://engine.hoshloop.com

# --- Phase 3: Embeddings (company memory / pgvector) ---
# Option A: OpenAI embeddings (text-embedding-3-small, 1536-dim)
OPENAI_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Option B: Voyage AI (Anthropic partner, 200M free tokens/mo)
# VOYAGE_API_KEY=pa-xxx
# EMBEDDING_MODEL=voyage-3-lite
# EMBEDDING_DIM=512

# --- Phase 6: Slack integration ---
SLACK_CLIENT_ID=xxx
SLACK_CLIENT_SECRET=xxx
SLACK_SIGNING_SECRET=xxx
SLACK_REDIRECT_URI=https://engine.hoshloop.com/api/slack/callback

# --- Phase 8: Reddit (read-only, for community intelligence) ---
REDDIT_CLIENT_ID=xxx
REDDIT_CLIENT_SECRET=xxx
REDDIT_USER_AGENT=HoshloopSEO/1.0 by u/yourreddithandle
